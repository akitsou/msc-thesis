\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces \textbf  {Metadata Annotation:} Each patient file is labelled with the patient's name. \textbf  {Chunking:} ``Recursive Character Text Splitter`` splits the text into chunks of 800 characters with 100-character overlap. \textbf  {Embedding model:} The embedding model ``paraphrase-multilingual-MiniLM-L12-v2`` encodes each chunk and stores it into the FAISS vector database, together with the patient's name annotation as its metadata.}}{65}{figure.caption.61}\protected@file@percent }
\newlabel{fig:BaselineChunkingEmbeddingFaiss}{{4.3}{65}{\textbf {Metadata Annotation:} Each patient file is labelled with the patient's name. \textbf {Chunking:} ``Recursive Character Text Splitter`` splits the text into chunks of 800 characters with 100-character overlap. \textbf {Embedding model:} The embedding model ``paraphrase-multilingual-MiniLM-L12-v2`` encodes each chunk and stores it into the FAISS vector database, together with the patient's name annotation as its metadata}{figure.caption.61}{}}
