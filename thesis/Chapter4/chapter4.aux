\@writefile{lof}{\contentsline {figure}{\numberline {4.1}{\ignorespaces \textbf  {Memory:} Custom memory. Stores current patient’s name. Replaces pronouns like ``της``,``αυτό``,``η ασθενής`` with the stored patient’s name. \textbf  {Encoder:} The embedding model paraphrase-multilingual-MiniLM-L12-v2 encodes the question. \textbf  {Retriever:} Finds relevant context passages from patient documents using the embedding model. \textbf  {LLM:} At the chain’s core lies the Gemma LLM with its default prompt.}}{62}{figure.caption.55}\protected@file@percent }
\newlabel{fig:Gemma}{{4.1}{62}{\textbf {Memory:} Custom memory. Stores current patient’s name. Replaces pronouns like ``της``,``αυτό``,``η ασθενής`` with the stored patient’s name. \textbf {Encoder:} The embedding model paraphrase-multilingual-MiniLM-L12-v2 encodes the question. \textbf {Retriever:} Finds relevant context passages from patient documents using the embedding model. \textbf {LLM:} At the chain’s core lies the Gemma LLM with its default prompt}{figure.caption.55}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.2}Second experiment with LLM: KriKri}{62}{subsection.4.2.2}\protected@file@percent }
