\contentsline {figure}{\numberline {2.1}{\ignorespaces AI in Healthcare Series: From Decision Support to Drug Prescriptions, Stanford Online, YouTube (video), Accessed on March 29, 2025. \url {https://www.youtube.com/watch?v=TC64U_rzEuI}}}{7}{figure.caption.6}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {3.1}{\ignorespaces Productizing Healthcare ChatBots with John Snow Labs' Medical LLM-as-a-Judge}}{46}{figure.caption.21}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {4.1}{\ignorespaces \textbf {Memory:} Custom memory. Stores current patient’s name. Replaces pronouns like ``της``,``αυτό``,``η ασθενής`` with the stored patient’s name. \textbf {Encoder:} The embedding model paraphrase-multilingual-MiniLM-L12-v2 encodes the question. \textbf {Retriever:} Finds relevant context passages from patient documents using the embedding model. \textbf {LLM:} At the chain’s core lies the Gemma LLM with its default prompt.}}{62}{figure.caption.55}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces \textbf {Memory:} Retrieves the last 3 exchanges and passes these as chat history to the prompt. \textbf {Encoder:} The embedding model paraphrase-multilingual-MiniLM-L12-v2 encodes the question. \textbf {Retriever:} Finds relevant context passages from patient documents using the embedding model. \textbf {Chain:} At the chain’s core lies the Llama-Krikri-8B-Instruct LLM. In its prompt it receives the retrieved context, the chat history, the nurse’s original question, and custom instructions on how to answer it.}}{64}{figure.caption.57}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces \textbf {Metadata Annotation:} Each patient file is labelled with the patient's name. \textbf {Chunking:} ``Recursive Character Text Splitter`` splits the text into chunks of 800 characters with 100-character overlap. \textbf {Embedding model:} The embedding model ``paraphrase-multilingual-MiniLM-L12-v2`` encodes each chunk and stores it into the FAISS vector database, together with the patient's name annotation as its metadata.}}{65}{figure.caption.61}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces \textbf {Memory:} Retrieves the last 3 exchanges and passes these as chat history to the prompt. \textbf {Encoder:} The embedding model paraphrase-multilingual-MiniLM-L12-v2 encodes the question. \textbf {Retriever:} Finds relevant context passages from patient documents using the embedding model. \textbf {Chain:} At the chain’s core lies the Gemini Flash 2.0 LLM. In its prompt it receives the retrieved context, the chat history, the nurse’s original question, and custom instructions on how to answer it.}}{67}{figure.caption.65}%
\contentsline {figure}{\numberline {4.5}{\ignorespaces \textbf {Metadata Annotation:} Each patient file is labelled with the patient's name. \textbf {Chunking:} ``Recursive Character Text Splitter`` splits the text into chunks of 550 characters with 50-character overlap. \textbf {Chunk Prefixing:} The patient's name and AMKA is appended to each chunk in order to make it identifiable and improve retrieval accuracy. \textbf {Embedding model:} The embedding model ``paraphrase-multilingual-MiniLM-L12-v2`` encodes each chunk and stores it into the Chroma vector database, together with the patient's name annotation as its metadata.}}{70}{figure.caption.70}%
\contentsline {figure}{\numberline {4.6}{\ignorespaces \textbf {Agent:} The agent is initialized with the tools, the memory, and the LLM. The agent decides what and when to use for each query. \textbf {Memory:} Holds the entire conversation history and passes it as chat history to the agent. It is updated automatically by the agent after each turn. \textbf {Tools:} Two custom tool functions are used to extract the patient name and then call the retriever filtering by that name.}}{72}{figure.caption.75}%
\contentsline {figure}{\numberline {4.7}{\ignorespaces Average scores for RAGAs metrics across 25 queries}}{80}{figure.caption.82}%
\contentsline {figure}{\numberline {4.8}{\ignorespaces System 1: Average scores for RAGAs metrics across 25 queries}}{82}{figure.caption.87}%
\contentsline {figure}{\numberline {4.9}{\ignorespaces System 2: Average scores for RAGAs metrics across 25 queries}}{84}{figure.caption.92}%
\contentsline {figure}{\numberline {4.10}{\ignorespaces Plot for query nr. 17. The assistant failed to disambiguate between two patients with the same name.}}{91}{figure.caption.100}%
