\@writefile{toc}{\contentsline {subsubsection}{Eight patients}{63}{section*.56}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces \textbf  {Memory:} Retrieves the last 3 exchanges and passes these as chat history to the prompt. \textbf  {Encoder:} The embedding model paraphrase-multilingual-MiniLM-L12-v2 encodes the question. \textbf  {Retriever:} Finds relevant context passages from patient documents using the embedding model. \textbf  {Chain:} At the chain’s core lies the Llama-Krikri-8B-Instruct LLM. In its prompt it receives the retrieved context, the chat history, the nurse’s original question, and custom instructions on how to answer it.}}{64}{figure.caption.57}\protected@file@percent }
\newlabel{fig:KriKri}{{4.2}{64}{\textbf {Memory:} Retrieves the last 3 exchanges and passes these as chat history to the prompt. \textbf {Encoder:} The embedding model paraphrase-multilingual-MiniLM-L12-v2 encodes the question. \textbf {Retriever:} Finds relevant context passages from patient documents using the embedding model. \textbf {Chain:} At the chain’s core lies the Llama-Krikri-8B-Instruct LLM. In its prompt it receives the retrieved context, the chat history, the nurse’s original question, and custom instructions on how to answer it}{figure.caption.57}{}}
